// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`HTML generation snapshots > captures frame layout, metadata, links, and escaped content 1`] = `
"<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="color-scheme" content="dark" />
  <meta name="generator" content="Frontendeasy" />
  <meta name="description" content="Plan &lt;strong&gt; &amp; ship &quot;safely&quot;" />
  <meta property="og:title" content="Share &lt;Launch&gt; &amp; Learn" />
  <meta property="og:description" content="Plan &lt;strong&gt; &amp; ship &quot;safely&quot;" />
  <meta property="og:image" content="https://example.test/image.png?size=large&amp;mode=dark" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="keywords" content="studio, &lt;design&gt;, ship &amp; learn" />
  <meta name="theme-color" content="#101010" />
  <title>Launch &lt;Page&gt; &amp; &quot;Proof&quot;</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Lora:wght@400;500;600;700&amp;display=swap" />
  <style>
    :root { --frontendeasy-font: 'Lora', system-ui, sans-serif; }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      background: linear-gradient(90deg, #101010, #202020);
      font-family: var(--frontendeasy-font);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    #__frontendeasy_canvas {
      position: relative;
      width: 1200px;
      height: 800px;
      overflow: hidden;
      transform-origin: top center;
    }
    #__frontendeasy_canvas a:hover { opacity: 0.85; transform: translateY(-1px); }
    #__frontendeasy_canvas a:active { opacity: 0.7; transform: translateY(0); }
    #__frontendeasy_canvas a:focus-visible { outline: 2px solid currentColor; outline-offset: 3px; border-radius: 4px; }
    .el-headline{position:absolute;left:48px;top:64px;width:520px;height:100px;background:transparent;color:#f5f5f5;border-radius:0px;font-size:40px;font-weight:700;display:flex;align-items:center;justify-content:center;box-sizing:border-box;padding:12px 16px;font-family:var(--frontendeasy-font);line-height:1.15;overflow:hidden;text-shadow:0px 2px 8px rgba(0, 0, 0, 0.4);margin:0;text-align:left;align-items:flex-start;overflow:visible;text-overflow:clip;overflow-wrap:break-word;word-break:break-word;white-space:pre-wrap}
    .el-cta{position:absolute;left:48px;top:204px;width:240px;height:56px;background:linear-gradient(90deg, #ffc44d, #ff9d3d);color:#101010;border-radius:12px;font-size:16px;font-weight:600;display:flex;align-items:center;justify-content:center;box-sizing:border-box;padding:12px 16px;font-family:var(--frontendeasy-font);line-height:1.35;overflow:hidden;text-decoration:none;cursor:pointer;transition:opacity 0.15s,transform 0.15s;white-space:nowrap}
  </style>
</head>
<body>
  <main id="__frontendeasy_canvas">
    <h1 class="el-headline" data-name="Headline &quot;Primary&quot;">Build &lt;fast&gt; &amp; &quot;clearly&quot;</h1>
    <a class="el-cta" href="details-and-specs.html" data-name="CTA &lt;next&gt;">Read &amp; compare &lt;now&gt;</a>
  </main>
  <script>
    (function () {
      var W = 1200, H = 800;
      var canvas = document.getElementById('__frontendeasy_canvas');
      function fit() {
        var vw = window.innerWidth;
        var s = vw < W ? vw / W : 1;
        if (s < 1) {
          canvas.style.transform = 'scale(' + s + ')';
          // Negative margin collapses the unused layout space the scaled canvas leaves below itself
          canvas.style.marginBottom = Math.ceil((s - 1) * H) + 'px';
        } else {
          canvas.style.transform = '';
          canvas.style.marginBottom = '';
        }
      }
      fit();
      window.addEventListener('resize', fit);
    })();
  </script>
</body>
</html>"
`;

