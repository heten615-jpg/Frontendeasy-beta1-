{
  "name": "frontendeasy",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/vite-build-strict.mjs",
    "build:budget": "npm run build && node scripts/check-bundle-budget.mjs",
    "analyze:bundle": "npm run build && node scripts/analyze-bundle.mjs",
    "analyze:bundle:dist": "node scripts/analyze-bundle.mjs",
    "generate:large-project": "node scripts/generate-large-project.mjs",
    "generate:release-notes": "node scripts/generate-release-notes.mjs",
    "generate:changelog": "node scripts/generate-release-notes.mjs",
    "lint:export": "node scripts/check-export-quality.mjs",
    "verify:release": "node scripts/check-release-readiness.mjs",
    "lint:types": "tsc -p tsconfig.app.json --noUnusedLocals --noUnusedParameters --noEmit && tsc -p tsconfig.node.json && node scripts/check-dead-exports.mjs",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "test": "vitest run",
    "test:e2e:smoke": "playwright test e2e/onboarding.spec.ts e2e/update-notes.spec.ts e2e/mobile-smoke.mobile.ts",
    "test:e2e": "playwright test",
    "test:e2e:perf": "playwright test --config=playwright.perf.config.ts"
  },
  "engines": {
    "node": "22.x"
  },
  "build": {
    "appId": "com.frontendeasy.studio",
    "productName": "Frontendeasy",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.graphics-design",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis"
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage"
        }
      ]
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^24.12.3",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.2.1",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "fake-indexeddb": "^6.2.5",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.8",
    "typescript": "~6.0.2",
    "uuid": "^14.0.0",
    "vite": "^8.0.12",
    "vitest": "^4.1.7",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@supabase/supabase-js": "^2.106.1",
    "codemirror": "^6.0.2"
  }
}
