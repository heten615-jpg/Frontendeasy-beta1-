# Frontendeasy environment variables — copy this file to `.env` and fill in.
# `.env` is gitignored. NEVER commit real secrets.
#
# Vite exposes only variables prefixed with `VITE_` to client code.
# The Supabase anon key is safe to ship to the browser (it's protected by RLS).
# The service-role key (NOT shown here) must never appear in the client bundle.

# ── Supabase ────────────────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-SUPABASE-ANON-PUBLIC-KEY

# When both vars are missing the app runs in offline-only mode (IndexedDB +
# localStorage). That's the expected experience for local development without
# a Supabase project yet.
